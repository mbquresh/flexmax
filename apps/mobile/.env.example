EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_EAS_PROJECT_ID=your-eas-project-id

# AI keys live in Supabase secrets only (never in the mobile app):
#   AI_PROVIDER=demo|gemini|anthropic
#   GEMINI_API_KEY=...       (free dev — aistudio.google.com/apikey)
#   ANTHROPIC_API_KEY=...    (production)
# Deploy with: ./scripts/setup-ai.sh gemini YOUR_KEY
